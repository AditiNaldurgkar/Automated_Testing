<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Notes Automation Suite" verbose="1" parallel="tests" thread-count="2">
    <listeners> //listener on failure
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <test name="UI - Login Tests">
        <classes>
            <class name="tests.ui.LoginTest"/>
        </classes>
    </test>

    <test name="UI - Note Creation Tests">
        <classes>
            <class name="tests.ui.NoteCreationTest"/>
        </classes>
    </test>

    <test name="UI - Note Edit Tests">
        <classes>
            <class name="tests.ui.NoteEditTest"/>
        </classes>
    </test>

    <test name="UI - Search And Edit Tests">
        <classes>
            <class name="tests.ui.NoteSearchAndEditTest"/>
        </classes>
    </test>

    <test name="API - Notes API Tests">
        <classes>
            <class name="tests.api.ApiTest"/>
        </classes>
    </test>

    <test name="E2E - Hybrid Tests">
        <classes>
            <class name="tests.e2e.Hybridtest"/>
        </classes>
    </test>

</suite>